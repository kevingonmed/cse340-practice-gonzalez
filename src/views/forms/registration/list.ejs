<%- include('../../partials/header') %>

    <main>
        <h1>Account Management</h1>

        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% users.forEach(u=> { %>
                    <tr>
                        <td>
                            <%= u.first_name %>
                                <%= u.last_name %>
                        </td>
                        <td>
                            <%= u.email %>
                        </td>
                        <td>
                            <%= u.role_name %>
                        </td>
                        <td>
                            <% if (user.roleName==='admin' || user.id===u.id) { %>
                                <a href="/register/<%= u.id %>/edit">Edit</a>
                                <% } %>
                                    <% if (user.roleName==='admin' || user.id===u.id) { %>
                                        <form action="/register/<%= u.id %>/delete" method="POST"
                                            style="display:inline;">
                                            <button type="submit"
                                                onclick="return confirm('Are you sure you want to delete this account?')">Delete</button>
                                        </form>
                                        <% } %>
                        </td>
                    </tr>
                    <% }); %>
            </tbody>
        </table>
    </main>

    <%- include('../../partials/footer') %>