<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>500 Error</title>
</head>

<body>

    <h1>500 - Internal Server Error</h1>

    <p>
        Sorry, something went wrong.
    </p>

    <% if (error) { %>

        <h3>Development Error:</h3>

        <p>
            <%= error %>
        </p>

        <% } %>

            <a href="/">
                Return Home
            </a>

</body>

</html>